# TiDB Cloud — get these from https://tidbcloud.com
# Serverless (Starter): sslaccept=strict is sufficient (Let's Encrypt certs in system trust store)
# Dedicated: also add sslcert=/path/to/ca.pem (download CA from TiDB Cloud console → Connect → CA cert)
DATABASE_URL="mysql://username@prefix.gcp tidbcloud.com:4000/database?sslaccept=strict"

# Windows note: if connection fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE,
# download ISRG Root X1 cert from https://letsencrypt.org/certs/lets-encrypt-r1.pem
# and add: &sslcert=C:/path/to/lets-encrypt-r1.pem

# Auth.js (NextAuth v5) — AUTH_ prefix replaces deprecated NEXTAUTH_ prefix
AUTH_SECRET="your-secret-key-here"
# AUTH_URL is auto-detected in production; only set for local dev if needed
# AUTH_URL="http://localhost:3000"

# Site URL — used for internal server-side fetches and SEO
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Decap CMS — no env vars needed (config in public/admin/config.yml)
# For production: enable Git Gateway in your hosting provider (Vercel/Netlify)
